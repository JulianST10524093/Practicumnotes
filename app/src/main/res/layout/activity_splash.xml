<?xml version="1.0" encoding="utf-8"?>
<!--
    STEP 1: LAYOUT CONTAINER
    The ConstraintLayout allows you to position elements relative to the screen or each other.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"> <!-- Change color to match your branding -->

    <!--
        STEP 2: APP LOGO
        Replace @mipmap/ic_launcher with your actual logo file.
    -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="100dp"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        STEP 3: STUDENT INFORMATION
        Mandatory for many assessments: Name and Student Number.
    -->
    <TextView
        android:id="@+id/txtStudentInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Name: [Your Name]\nStudent ID: [ST123456]"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgLogo" />

    <!--
        STEP 4: NAVIGATION BUTTON
        This button will trigger the logic in SplashActivity.kt to open the Main Screen.
    -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="ENTER APP"
        app:layout_constraintBottom_toTopOf="@+id/btnExitSplash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!--
        STEP 5: EXIT BUTTON
        Provides a clean way for the user to close the application.
    -->
    <Button
        android:id="@+id/btnExitSplash"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        android:text="EXIT"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>